# Runtime state (user-side; never shipped) — recursive to catch nested test dirs
**/state/
**/cache/
**/logs/
state/
cache/
logs/

# Dev-mode marker (only ever exists under $XDG_CONFIG_HOME, but belt-and-suspenders
# in case a contributor runs `pa dev on` from inside the repo during testing)
dev-path
*.snapshot

# User-owned learnings (template only ships as learnings.example.md)
**/learnings.md
!presets/*/learnings.example.md

# Backups from migration script
*.bak
*.bak.*

# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Editor noise
.vscode/
.idea/
*.swp
*~

# Local-only dev artifacts
.env
.env.local
