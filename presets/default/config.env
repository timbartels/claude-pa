# default preset — generic PARA-light Obsidian vault assumptions.
#
# Parsed by lib/pa/preset_loader.py with a strict KEY=VALUE allowlist.
# This file is NEVER sourced as bash. Allowed: literal values, $VAR refs
# (expanded at parse time), and literal {placeholders} for the spawn
# template. NOT allowed: $(…), backticks, ${VAR}, escapes.
#
# Required-key omission is intentional: PA_VAULT and PA_PROJECTS_DIR
# come from the user (auto-detect in `pa init` default mode, --set in
# --preset mode, or the wizard). Everything below is the vault-org
# fallback layer the wizard reaches for when nothing else resolves.

PA_TERMINAL_BACKEND=auto
PA_MAIN_TITLE=MAIN

PA_DAILY_DIR=Daily
PA_DAILY_TEMPLATE_PATH="_templates/Daily Note.md"
PA_WORK_SECTION=Work
PA_PERSONAL_SECTION=Personal
PA_FEATURE_NOTE_DIR=PROJECTS

# Five-stage taxonomy covers the common solo-developer workflow:
#   brainstorming  → exploring requirements
#   planned        → spec written, ready to implement
#   in-progress    → writing code
#   in-review      → PR open, waiting on review
#   shipped        → merged
PA_STATUS_VALUES="brainstorming,planned,in-progress,in-review,shipped"
PA_STATUS_SHIPPED=shipped

PA_SPAWN_PROMPT_TEMPLATE=""

PA_DASHBOARD_INTERVAL=2
PA_DEBUG=0
