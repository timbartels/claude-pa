# obsidian-ce preset — Obsidian + Compound Engineering workflows.
#
# Parsed by lib/pa/preset_loader.py with a strict KEY=VALUE allowlist.
# This file is NEVER sourced as bash. Allowed: literal values, $VAR refs
# (expanded at parse time), and literal {placeholders} for the spawn
# template. NOT allowed: $(…), backticks, ${VAR}, escapes.

PA_VAULT="$HOME/Documents/MyVault"
PA_PROJECTS_DIR=$HOME/Projects

PA_TERMINAL_BACKEND=wezterm
PA_MAIN_TITLE="MAIN · MyVault"

PA_DAILY_DIR=Daily
PA_DAILY_TEMPLATE_PATH="_templates/Daily Note.md"
PA_WORK_SECTION=Work
PA_PERSONAL_SECTION=Personal
PA_FEATURE_NOTE_DIR=PROJECTS

# The six-stage taxonomy reflects a multi-repo rollout pattern:
#   brainstorming  → /workflows:brainstorm
#   planned        → /workflows:plan
#   in-progress    → /workflows:work
#   in-dev         → merged to dev branch, awaiting QA
#   in-review      → PR open, waiting for review
#   shipped        → merged to main, ticked in daily
PA_STATUS_VALUES="brainstorming,planned,in-progress,in-review,in-dev,shipped"
PA_STATUS_SHIPPED=shipped

# CE workflow injection: when pa spawn / pa restart fires without an
# explicit prompt, this template is substituted and sent to the project
# pane. The receiving Claude reads the SessionStart vault-context hook's
# feature-note injection plus this slash command.
PA_SPAWN_PROMPT_TEMPLATE="/workflows:brainstorm {title} — {intent} | {context}"

PA_DASHBOARD_INTERVAL=2
PA_DEBUG=0
