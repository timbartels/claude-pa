#!/usr/bin/env bash
# pa — claude-pa launcher.
#
# Loads the claude-pa plugin into a Claude Code session. Bare invocation
# orchestrates the vault session (cd into $PA_VAULT, ensure dashboard pane,
# tag the orchestrator pane, then exec claude with the personal-assistant
# slash command — or resume same-day session via --continue).
#
# Supports a `dev` toggle that swaps between the marketplace-installed
# plugin and a local dev checkout via `claude --plugin-dir`. The toggle
# persists across shells/reboots in a marker file at
# $XDG_CONFIG_HOME/claude-pa/dev-path.
#
# Usage:
#   pa                       launch the vault session (dev plugin if `pa dev on`, marketplace otherwise)
#   pa dev on [path]         enable dev mode; default path: ~/Projects/claude-pa
#   pa dev off               disable dev mode (back to marketplace install)
#   pa dev status            show current mode + active path
#
# Future subcommands (Phase 5 of the implementation plan):
#   pa init                  interactive wizard
#   pa doctor                health check
#   pa uninstall             clean removal

set -euo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claude-pa"
DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/claude-pa"
DEV_MARKER="$CONFIG_DIR/dev-path"
SLASH_COMMAND="/claude-pa:personal-assistant"

# Color helpers — gate on stdout TTY since user-facing output prints to stdout.
# Diagnostics (die/note/warn) print to stderr but use the same gate for consistency.
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  RED=$'\033[31m'; YELLOW=$'\033[33m'; CYAN=$'\033[36m'; RESET=$'\033[0m'
else
  RED=''; YELLOW=''; CYAN=''; RESET=''
fi

die() { local msg="$1" code="${2:-1}"; printf '%serror:%s %s\n' "$RED" "$RESET" "$msg" >&2; exit "$code"; }
note() { printf '%snote:%s %s\n' "$CYAN" "$RESET" "$*" >&2; }
warn() { printf '%swarning:%s %s\n' "$YELLOW" "$RESET" "$*" >&2; }

# Resolve a user-supplied path to its canonical form and reject anything
# outside $HOME (the only place a dev checkout legitimately lives). Set
# PA_ALLOW_EXTERNAL=1 to override (e.g. shared system installs).
_pa_resolve_safe() {
  local path="$1" resolved
  if command -v realpath >/dev/null 2>&1; then
    resolved=$(realpath -- "$path" 2>/dev/null) || resolved=""
  else
    # macOS fallback: portable canonicalization via cd
    resolved=$(cd -- "$path" 2>/dev/null && pwd -P) || resolved=""
  fi
  [[ -n "$resolved" ]] || { printf 'invalid path: %s\n' "$path" >&2; return 1; }
  if [[ "${PA_ALLOW_EXTERNAL:-0}" != "1" ]] && [[ "$resolved" != "$HOME"/* ]]; then
    printf 'path outside $HOME: %s (set PA_ALLOW_EXTERNAL=1 to override)\n' "$resolved" >&2
    return 1
  fi
  printf '%s\n' "$resolved"
}

# Validate that a directory is a claude-pa plugin install (used by dev_on and
# by the exec path to re-check on every launch — TOCTOU defense).
_pa_validate_plugin_dir() {
  local path="$1"
  [[ -d "$path" ]] || { printf 'not a directory: %s\n' "$path" >&2; return 1; }
  [[ -f "$path/.claude-plugin/plugin.json" ]] \
    || { printf 'not a claude-pa plugin (missing .claude-plugin/plugin.json): %s\n' "$path" >&2; return 1; }
}

# Snapshot rotation: keep the N most recent .learnings.bak-* files.
_pa_rotate_snapshots() {
  local keep=5
  ls -1t "$DATA_DIR"/.learnings.bak-* 2>/dev/null \
    | awk -v k="$keep" 'NR > k' \
    | xargs -r rm --
}

# Resolve the directory containing this script, following symlinks.
# Supports the documented install pattern (`ln -s … ~/.local/bin/pa`).
_pa_script_dir() {
  local script="$0" target
  while [[ -L "$script" ]]; do
    target=$(readlink "$script")
    if [[ "$target" = /* ]]; then
      script="$target"
    else
      script="$(cd "$(dirname "$script")" && pwd)/$target"
    fi
  done
  cd "$(dirname "$script")" && pwd
}

# Detect the active pane id for the configured (or autodetected) backend.
# Mirrors the lookup in hooks/scripts/mark-main-pane.sh + lib/pa/state_update.py.
_pa_active_pane() {
  case "${PA_TERMINAL_BACKEND:-}" in
    wezterm) printf '%s' "${WEZTERM_PANE:-}" ;;
    tmux)    printf '%s' "${TMUX_PANE:-}" ;;
    iterm2)  printf '%s' "${ITERM_SESSION_ID:-}" ;;
    kitty)   printf '%s' "${KITTY_WINDOW_ID:-}" ;;
    *)       printf '%s' "${TMUX_PANE:-${WEZTERM_PANE:-${ITERM_SESSION_ID:-${KITTY_WINDOW_ID:-}}}}" ;;
  esac
}

# Source PA_CONFIG inline (best-effort — orchestration steps each handle
# their own absence-of-config gracefully).
_pa_load_config_inline() {
  local cfg="${XDG_CONFIG_HOME:-$HOME/.config}/claude-pa/config.sh"
  [[ -f "$cfg" ]] || return 1
  # shellcheck disable=SC1090
  source "$cfg"
  return 0
}

# Run the vault-session orchestration: cd to vault, ensure dashboard pane,
# tag this pane as the orchestrator, return 0 if same-day resume applies.
# Sets globals: PA_VAULT_DIR, PA_RESUME (true|false).
_pa_orchestrate_vault_session() {
  local pa_sh="$1"

  if ! _pa_load_config_inline; then
    warn "no config at \$XDG_CONFIG_HOME/claude-pa/config.sh — launching without vault orchestration"
    PA_VAULT_DIR=""
    PA_RESUME=false
    return 0
  fi

  PA_VAULT_DIR="${PA_VAULT:-}"
  if [[ -z "$PA_VAULT_DIR" || ! -d "$PA_VAULT_DIR" ]]; then
    warn "PA_VAULT is unset or not a directory — launching without vault orchestration"
    PA_VAULT_DIR=""
    PA_RESUME=false
    return 0
  fi

  # Dashboard spawn is wezterm-gated inside pa.sh; on other backends it
  # exits 0 with a message. Either way: best-effort, never fatal.
  "$pa_sh" dashboard 0.5 >/dev/null 2>&1 || true

  # Auto-resume project panes whose state files survived. Clean shutdowns
  # delete state via SessionEnd hook, so a surviving state file = unclean
  # exit (terminal crash / accidental close). resume re-spawns each with
  # `claude --continue`. No-op if state dir empty.
  "$pa_sh" resume >/dev/null 2>&1 || true

  # Tag this pane as the orchestrator. Same pane-id detection as the hook.
  local pane
  pane=$(_pa_active_pane)
  if [[ -n "$pane" ]]; then
    "$pa_sh" focus "$pane" "${PA_MAIN_TITLE:-MAIN}" >/dev/null 2>&1 || true
  fi

  # Same-day resume check: skill writes session-touch --morning-done at
  # the end of step 9. If it ran already today, `claude --continue` wins.
  if "$pa_sh" session-resumable >/dev/null 2>&1; then
    PA_RESUME=true
  else
    PA_RESUME=false
  fi
  return 0
}

dev_on() {
  local input_path="${1:-$HOME/Projects/claude-pa}" path
  path=$(_pa_resolve_safe "$input_path") || die "rejected: $input_path" 2
  _pa_validate_plugin_dir "$path" || die "rejected: $path" 2

  install -d -m 700 -- "$CONFIG_DIR"

  # Snapshot learnings.md if present (only irreplaceable file; state is transient).
  if [[ -f "$DATA_DIR/learnings.md" ]]; then
    install -d -m 700 -- "$DATA_DIR"
    local ts; ts=$(date +%s)
    install -m 600 -- "$DATA_DIR/learnings.md" "$DATA_DIR/.learnings.bak-$ts"
    note "snapshot: $DATA_DIR/.learnings.bak-$ts"
    _pa_rotate_snapshots
  fi

  # Write marker atomically; umask 077 enforces 600 perms on creation.
  # Resolved (canonical) path persisted, not the user-supplied string.
  (
    umask 077
    printf '%s\n' "$path" > "$DEV_MARKER.tmp"
  )
  mv -f -- "$DEV_MARKER.tmp" "$DEV_MARKER"

  printf 'dev mode %sON%s\n' "$CYAN" "$RESET"
  printf 'plugin path: %s\n' "$path"
  printf 'next `pa` launches: claude --plugin-dir %s\n' "$path"
}

dev_off() {
  if [[ -f "$DEV_MARKER" ]]; then
    rm "$DEV_MARKER"
    printf 'dev mode %sOFF%s (marketplace install active)\n' "$CYAN" "$RESET"
  else
    printf 'dev mode already off\n'
  fi
}

dev_status() {
  if [[ "${1:-}" == "--json" ]]; then
    if [[ -f "$DEV_MARKER" ]]; then
      local path; path=$(cat "$DEV_MARKER")
      local valid=false
      _pa_validate_plugin_dir "$path" >/dev/null 2>&1 && valid=true
      printf '{"mode":"dev","path":"%s","valid":%s}\n' "$path" "$valid"
    else
      printf '{"mode":"production","path":null,"valid":true}\n'
    fi
    return 0
  fi
  if [[ -f "$DEV_MARKER" ]]; then
    local path; path=$(cat "$DEV_MARKER")
    printf 'mode: %sDEV%s\nplugin path: %s\n' "$CYAN" "$RESET" "$path"
    _pa_validate_plugin_dir "$path" >/dev/null 2>&1 \
      || warn "dev path no longer valid; run \`pa dev off\` or \`pa dev on <new-path>\`"
  else
    printf 'mode: production (marketplace install)\n'
  fi
}

case "${1:-}" in
  dev)
    case "${2:-status}" in
      on)     shift 2 || true; dev_on "${1:-}" ;;
      off)    dev_off ;;
      status) shift 2 || true; dev_status "${1:-}" ;;
      *)      die "usage: pa dev {on [path]|off|status [--json]}" 2 ;;
    esac
    ;;
  init|doctor|uninstall)
    sub="$1"; shift
    wizard_lib="$(_pa_script_dir)/../lib/wizard.sh"
    if [[ -f "$DEV_MARKER" ]]; then
      _dev_path=$(cat "$DEV_MARKER")
      [[ -f "$_dev_path/lib/wizard.sh" ]] && wizard_lib="$_dev_path/lib/wizard.sh"
    fi
    [[ -f "$wizard_lib" ]] || die "wizard lib not found at $wizard_lib" 1
    # shellcheck source=../lib/wizard.sh
    source "$wizard_lib"
    "pa_${sub}" "$@"
    ;;
  -h|--help|help)
    sed -n '/^# pa/,/^$/p' "$0" | sed 's/^# \{0,1\}//'
    ;;
  '')
    # Pick the plugin install we will run against.
    if [[ -f "$DEV_MARKER" ]]; then
      plugin_path=$(cat "$DEV_MARKER")
      # Re-validate on every launch — defense against marker tampering (TOCTOU)
      # and against the dev checkout being deleted/moved after `pa dev on`.
      _pa_validate_plugin_dir "$plugin_path" \
        || die "dev path invalid: $plugin_path — run \`pa dev off\` or \`pa dev on <path>\`" 2
      _pa_resolve_safe "$plugin_path" >/dev/null \
        || die "dev path failed safety check: $plugin_path" 2
      PA_SH="$plugin_path/bin/pa.sh"
      claude_plugin_flag=( --plugin-dir "$plugin_path" )
    else
      # Marketplace install: this launcher lives at <plugin>/bin/pa, and pa.sh
      # is its sibling. Resolve through symlinks so ~/.local/bin/pa → real
      # path works.
      script_dir=$(_pa_script_dir)
      PA_SH="$script_dir/pa.sh"
      claude_plugin_flag=()
    fi

    if [[ ! -x "$PA_SH" ]]; then
      die "pa.sh not found or not executable at $PA_SH" 1
    fi

    # Run vault-session pre-flight (cd $PA_VAULT, ensure dashboard pane,
    # tag the orchestrator pane, decide resume vs full morning routine).
    PA_VAULT_DIR=""
    PA_RESUME=false
    _pa_orchestrate_vault_session "$PA_SH"

    # cd into the vault when we have one — keeps Claude's CWD predictable
    # so the SessionStart vault-context hook can recognize this as the
    # orchestrator session (it skips state writes for vault-cwd sessions).
    if [[ -n "$PA_VAULT_DIR" ]]; then
      cd "$PA_VAULT_DIR"
    fi

    if [[ "$PA_RESUME" == "true" ]]; then
      note "resuming today's session (morning already done)"
      exec claude ${claude_plugin_flag[@]+"${claude_plugin_flag[@]}"} --continue
    fi
    exec claude ${claude_plugin_flag[@]+"${claude_plugin_flag[@]}"} "$SLASH_COMMAND"
    ;;
  *)
    die "unknown subcommand: $1 (try \`pa help\`)" 2
    ;;
esac
